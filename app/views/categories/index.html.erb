<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
  <h2 class="fw-bold">Manage Categories</h2>
  <%= link_to "+ New Category", new_category_path, class: "btn btn-custom-yellow shadow-sm" %>
</div>

<div class="card shadow-sm border-0">
  <ul class="list-group list-group-flush">
    <% @categories.each do |category| %>
      <li class="list-group-item d-flex justify-content-between align-items-center p-3">
        <div>
          <h5 class="mb-0 fw-bold"><%= category.name %></h5>
          <small class="text-muted"><%= category.description %></small>
        </div>
        <div>
          <%= link_to "Edit", edit_category_path(category), class: "btn btn-sm btn-outline-dark me-2" %>
          <%= button_to "Delete", category, method: :delete, class: "btn btn-sm btn-outline-danger inline-block", form: { style: 'display:inline-block;' }, data: { turbo_confirm: "Are you sure?" } %>
        </div>
      </li>
    <% end %>
  </ul>
</div>
