<%= form_with(model: category, local: true) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", required: true %>
  </div>
  <div class="mb-3">
    <%= form.label :description, class: "form-label fw-bold" %>
    <%= form.text_area :description, class: "form-control", rows: 3 %>
  </div>
  <div class="d-flex justify-content-end gap-2 mt-4">
    <%= link_to "Cancel", categories_path, class: "btn btn-outline-secondary" %>
    <%= form.submit "Save Category", class: "btn btn-custom-yellow" %>
  </div>
<% end %>