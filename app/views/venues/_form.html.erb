<%= form_with(model: venue, local: true) do |form| %>
  <div class="mb-3">
    <%= form.label :name, class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", required: true %>
  </div>
  <div class="mb-3">
    <%= form.label :location, class: "form-label fw-bold" %>
    <%= form.text_field :location, class: "form-control", required: true %>
  </div>
  <div class="mb-3">
    <%= form.label :capacity, class: "form-label fw-bold" %>
    <%= form.number_field :capacity, class: "form-control", required: true, min: 1 %>
  </div>
  <div class="d-flex justify-content-end gap-2 mt-4">
    <%= link_to "Cancel", venues_path, class: "btn btn-outline-secondary" %>
    <%= form.submit "Save Venue", class: "btn btn-custom-yellow" %>
  </div>
<% end %>