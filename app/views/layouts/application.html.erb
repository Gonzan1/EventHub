<!DOCTYPE html>
<html>
  <head>
    <title>EventHub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= javascript_importmap_tags %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://unpkg.com/trix@2.0.8/dist/trix.css">
    
    <style>
      :root { --brand-yellow: #FFE600; }
      body { background-color: #F7F7F7; }
      .navbar-brand { color: var(--brand-yellow) !important; transition: color 0.3s ease; }
      .navbar-brand:hover { color: #ffffff !important; }
      .menu-link { color: #ffffff !important; padding: 8px 20px !important; border-radius: 5px; transition: all 0.3s ease-in-out; margin: 0 5px; text-decoration: none; }
      .menu-link:hover { background-color: var(--brand-yellow) !important; color: #000000 !important; }
      .btn-custom-yellow { background-color: var(--brand-yellow); color: #000000; font-weight: bold; border: none; }
      .btn-custom-yellow:hover { background-color: #e6cf00; color: #000000; }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
      <div class="container">
        <%= link_to "EventHub", root_path, class: "navbar-brand fw-bold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item">
              <%= link_to "Events", events_path, class: "nav-link menu-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Categories", categories_path, class: "nav-link menu-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "Venues", venues_path, class: "nav-link menu-link" %>
            </li>

            <% if user_signed_in? %>
              <li class="nav-item dropdown ms-2">
                <a class="nav-link dropdown-toggle text-white fw-semibold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  👤 <%= current_user.email %> <span class="badge bg-secondary ms-1"><%= current_user.role %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                  <li><%= link_to "Editar Perfil", edit_user_registration_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= link_to "Cerrar Sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item text-danger" %>
                  </li>
                </ul>
              </li>
            <% else %>
              <li class="nav-item ms-2">
                <%= link_to "Iniciar Sesión", new_user_session_path, class: "nav-link text-white-50" %>
              </li>
              <li class="nav-item ms-2">
                <%= link_to "Registrarse", new_user_registration_path, class: "btn btn-custom-yellow btn-sm px-3 text-dark" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success text-center m-0">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-danger text-center m-0">
        <%= alert %>
      </div>
    <% end %>
 
    <div class="container mt-5">
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>