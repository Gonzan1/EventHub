<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow mt-4 mb-5 border-0">
      <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0 fw-bold">Edit Event</h3>
        <%= button_to "Delete Event", @event, method: :delete, class: "btn btn-danger btn-sm fw-bold", data: { turbo_confirm: "Are you sure you want to delete this event?" } %>
      </div>
      <div class="card-body p-4">
        <%= render "form", event: @event %>
      </div>
    </div>
  </div>
</div>
