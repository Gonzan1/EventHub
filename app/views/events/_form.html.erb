<%= form_with(model: event, local: true) do |form| %>
  <% if event.errors.any? %>
    <div class="alert alert-danger shadow-sm">
      <h5 class="alert-heading"><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h5>
      <ul class="mb-0">
        <% event.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label fw-bold" %>
    <%= form.text_field :title, class: "form-control", required: true, placeholder: "e.g., Python Clustering Workshop" %>
  </div>

  <div class="mb-4">
    <%= form.label :description, class: "form-label fw-bold" %>
    <%= form.rich_text_area :description, class: "form-control bg-white", required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :category_id, "Category", class: "form-label fw-bold" %>
      <%= form.collection_select :category_id, Category.all, :id, :name, { prompt: "Select a Category" }, { class: "form-select", required: true } %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :venue_id, "Venue", class: "form-label fw-bold" %>
      <%= form.collection_select :venue_id, Venue.all, :id, :name, { prompt: "Select a Venue" }, { class: "form-select", required: true } %>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <%= form.label :start_date, class: "form-label fw-bold" %>
      <%= form.datetime_field :start_date, class: "form-control", required: true %>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :end_date, class: "form-label fw-bold" %>
      <%= form.datetime_field :end_date, class: "form-control", required: true %>
    </div>
    <div class="col-md-4 mb-3">
      <%= form.label :capacity, class: "form-label fw-bold" %>
      <%= form.number_field :capacity, class: "form-control", required: true, min: 1 %>
    </div>
  </div>

  <% if event.persisted? %>
    <div class="card bg-light mb-4 border-0">
      <div class="card-body">
        <%= form.label :status, "Event Status (Publish / Cancel)", class: "form-label fw-bold" %>
        <%= form.select :status, Event.statuses.keys.map { |s| [s.capitalize, s] }, {}, class: "form-select border-secondary" %>
      </div>
    </div>
  <% end %>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
    <%= link_to "Cancel", events_path, class: "btn btn-outline-secondary" %>
    <%= form.submit "Save Event", class: "btn btn-custom-yellow" %>
  </div>
<% end %>