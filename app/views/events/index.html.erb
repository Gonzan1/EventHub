<div class="row mb-4">
  <div class="col">
    <h1 class="fw-bold">Explore Events</h1>
    <p class="text-muted">Discover and join activities around the campus.</p>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% @events.each do |event| %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <span class="badge bg-primary mb-2"><%= event.category.name %></span>
          <h5 class="card-title fw-bold"><%= event.title %></h5>
          <p class="card-text text-muted small"><%= truncate(event.description, length: 100) %></p>
          
          <ul class="list-unstyled small mb-0">
            <li><strong>📍 Venue:</strong> <%= event.venue.name %></li>
            <li><strong>📅 Date:</strong> <%= event.start_date.strftime("%B %d, %Y") %></li>
            <li><strong>👥 Spots:</strong> <%= event.capacity %></li>
            <li><strong>🏷️ Status:</strong> <%= event.status.capitalize %></li>
          </ul>
        </div>
        <div class="card-footer bg-white border-top-0">
          <%= link_to "View Details", event_path(event), class: "btn btn-outline-dark w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>